make_kegg_color_url <- function(kegg_df, pathway_id = "mmu00010") {
dataset <- kegg_df %>%
dplyr::filter(!is.na(kegg_id), !is.na(html_color)) %>%
dplyr::distinct(kegg_id, html_color) %>%
dplyr::mutate(
# KEGG wants %23 instead of raw # for hex colors
html_color = stringr::str_replace(html_color, "^#", "%23"),
line = paste0(kegg_id, "+", html_color, ",black")
) %>%
dplyr::pull(line) %>%
paste(collapse = "%0d%0a")
paste0(
"https://www.kegg.jp/kegg-bin/show_pathway?",
"map=", pathway_id,
"&multi_query=", dataset
)
}
save_kegg_colored_pathway <- function(kegg_df, pathway_id, output_png) {
kegg_url <- make_kegg_color_url(kegg_df, pathway_id)
message("Trying KEGG URL: ", kegg_url)
response <- httr::GET(
kegg_url,
httr::timeout(60),
httr::user_agent("R KEGG pathway coloring script")
)
if (httr::http_error(response)) {
warning("KEGG request failed for: ", output_png)
return(NA_character_)
}
page <- xml2::read_html(httr::content(response, as = "text", encoding = "UTF-8"))
img_src <- page %>%
xml2::xml_find_first(".//img[contains(@src, 'show_pathway')]") %>%
xml2::xml_attr("src")
if (is.na(img_src)) {
warning("Could not find pathway image for: ", output_png)
return(NA_character_)
}
img_url <- ifelse(
stringr::str_detect(img_src, "^https?://"),
img_src,
paste0("https://www.kegg.jp", img_src)
)
img_response <- httr::GET(
img_url,
httr::timeout(60),
httr::write_disk(output_png, overwrite = TRUE)
)
if (httr::http_error(img_response)) {
warning("Could not download KEGG image for: ", output_png)
return(NA_character_)
}
output_png
}
