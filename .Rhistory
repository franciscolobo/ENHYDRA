library(readxl)
library(dplyr)
library(purrr)
library(stringr)
library(msigdbr)
library(writexl)
library(AnnotationDbi)
library(org.Mm.eg.db)
library(httr)
library(xml2)
glycolysis_genes
make_kegg_color_url <- function(kegg_df, pathway_id = "mmu00010") {
dataset <- kegg_df %>%
dplyr::filter(!is.na(kegg_id), !is.na(html_color)) %>%
dplyr::transmute(
line = paste0(kegg_id, " ", html_color, ",#000000")
) %>%
dplyr::pull(line) %>%
paste(collapse = "\r\n")
paste0(
"https://www.kegg.jp/kegg-bin/show_pathway?",
"map=", pathway_id,
"&multi_query=", utils::URLencode(dataset, reserved = TRUE)
)
}
save_kegg_colored_pathway <- function(kegg_df, pathway_id, output_png) {
kegg_url <- make_kegg_color_url(kegg_df, pathway_id)
page <- xml2::read_html(kegg_url)
img_src <- page %>%
xml2::xml_find_first(".//img[contains(@src, 'show_pathway')]") %>%
xml2::xml_attr("src")
if (is.na(img_src)) {
stop("Could not find pathway image in KEGG response.")
}
img_url <- paste0("https://www.kegg.jp", img_src)
httr::GET(
img_url,
httr::write_disk(output_png, overwrite = TRUE)
)
output_png
}
parse_deg_sheet <- function(file, sheet, padj_cutoff = 0.05) {
df <- read_excel(file, sheet = sheet)
names(df) <- names(df) %>%
str_replace_all("\\s+", "_") %>%
str_replace_all("\\.", "_") %>%
tolower()
gene_col  <- intersect(names(df), c("geneid", "gene_symbol", "symbol"))[1]
logfc_col <- intersect(names(df), c("avg_log2fc", "log2fc", "avg_logfc"))[1]
padj_col  <- intersect(names(df), c("p_val_adj", "padj", "fdr"))[1]
if (any(is.na(c(gene_col, logfc_col, padj_col)))) {
stop(
paste0(
"Could not identify required columns in file: ",
basename(file),
", sheet: ",
sheet,
"\nAvailable columns are: ",
paste(names(df), collapse = ", ")
)
)
}
df %>%
transmute(
gene_symbol = as.character(.data[[gene_col]]),
log2FC = .data[[logfc_col]],
padj = .data[[padj_col]]
) %>%
inner_join(
mouse_symbol_to_kegg,
by = c("gene_symbol" = "SYMBOL")
) %>%
mutate(
regulation = case_when(
is.na(padj) | padj >= padj_cutoff ~ "not_significant",
log2FC > 0 ~ "overexpressed",
log2FC < 0 ~ "underexpressed",
TRUE ~ "not_significant"
),
html_color = case_when(
regulation == "not_significant" ~ "#FFFF00", # yellow
regulation == "overexpressed" ~ "#FF0000",   # red
regulation == "underexpressed" ~ "#00FF00"   # green
)
) %>%
dplyr::select(
gene_symbol,
entrez_id = ENTREZID,
kegg_id,
log2FC,
padj,
regulation,
html_color
) %>%
arrange(gene_symbol)
}
walk(files, function(file) {
sheets <- excel_sheets(file)
sheet_results <- set_names(
map(sheets, ~ parse_deg_sheet(file, .x)),
sheets
)
file_prefix <- tools::file_path_sans_ext(basename(file))
output_file <- file.path(
output_dir,
paste0(file_prefix, "_glycolysis_KEGG_colors.xlsx")
)
write_xlsx(sheet_results, output_file)
# Save one colored KEGG glycolysis pathway image per sheet/comparison
imap(sheet_results, function(result_df, sheet_name) {
safe_sheet_name <- sheet_name %>%
str_replace_all("[^A-Za-z0-9_]+", "_") %>%
str_replace_all("_+", "_") %>%
str_remove("_$")
output_png <- file.path(
output_dir,
paste0(file_prefix, "_", safe_sheet_name, "_mmu00010_glycolysis.png")
)
save_kegg_colored_pathway(
kegg_df = result_df,
pathway_id = "mmu00010",
output_png = output_png
)
})
})
rlang::last_trace()
# Mouse gene symbol -> Entrez ID
# KEGG mouse gene IDs are usually formatted as mmu:EntrezID
mouse_symbol_to_kegg <- AnnotationDbi::select(
org.Mm.eg.db,
keys = glycolysis_genes,
keytype = "SYMBOL",
columns = c("SYMBOL", "ENTREZID")
) %>%
as_tibble() %>%
filter(!is.na(ENTREZID)) %>%
distinct(SYMBOL, ENTREZID) %>%
mutate(kegg_id = paste0("mmu:", ENTREZID))
input_dir <- "~/Projects/Mark/Matt/results/09_23_2025/DEGs/"
output_dir <- "~/Projects/Mark/Matt/results/09_23_2025/DEGs_for_KEGG/"
dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)
files <- list.files(
input_dir,
pattern = "\\.xlsx$",
full.names = TRUE
)
make_kegg_color_url <- function(kegg_df, pathway_id = "mmu00010") {
dataset <- kegg_df %>%
dplyr::filter(!is.na(kegg_id), !is.na(html_color)) %>%
dplyr::distinct(kegg_id, html_color) %>%
dplyr::transmute(
line = paste0(kegg_id, " ", html_color, ",#000000")
) %>%
dplyr::pull(line) %>%
paste(collapse = "\n")
paste0(
"https://www.kegg.jp/kegg-bin/show_pathway?",
"map=", pathway_id,
"&multi_query=", utils::URLencode(dataset, reserved = TRUE)
)
}
save_kegg_colored_pathway <- function(kegg_df, pathway_id, output_png) {
kegg_url <- make_kegg_color_url(kegg_df, pathway_id)
response <- httr::GET(
kegg_url,
httr::timeout(60),
httr::user_agent("R KEGG pathway coloring script")
)
if (httr::http_error(response)) {
warning("KEGG request failed for: ", output_png)
return(NA_character_)
}
page <- xml2::read_html(httr::content(response, as = "text", encoding = "UTF-8"))
img_src <- page %>%
xml2::xml_find_first(".//img[contains(@src, 'show_pathway')]") %>%
xml2::xml_attr("src")
if (is.na(img_src)) {
warning("Could not find pathway image for: ", output_png)
return(NA_character_)
}
img_url <- ifelse(
stringr::str_detect(img_src, "^https?://"),
img_src,
paste0("https://www.kegg.jp", img_src)
)
img_response <- httr::GET(
img_url,
httr::timeout(60),
httr::write_disk(output_png, overwrite = TRUE)
)
if (httr::http_error(img_response)) {
warning("Could not download KEGG image for: ", output_png)
return(NA_character_)
}
output_png
}
parse_deg_sheet <- function(file, sheet, padj_cutoff = 0.05) {
df <- read_excel(file, sheet = sheet)
names(df) <- names(df) %>%
str_replace_all("\\s+", "_") %>%
str_replace_all("\\.", "_") %>%
tolower()
gene_col  <- intersect(names(df), c("geneid", "gene_symbol", "symbol"))[1]
logfc_col <- intersect(names(df), c("avg_log2fc", "log2fc", "avg_logfc"))[1]
padj_col  <- intersect(names(df), c("p_val_adj", "padj", "fdr"))[1]
if (any(is.na(c(gene_col, logfc_col, padj_col)))) {
stop(
paste0(
"Could not identify required columns in file: ",
basename(file),
", sheet: ",
sheet,
"\nAvailable columns are: ",
paste(names(df), collapse = ", ")
)
)
}
df %>%
transmute(
gene_symbol = as.character(.data[[gene_col]]),
log2FC = .data[[logfc_col]],
padj = .data[[padj_col]]
) %>%
inner_join(
mouse_symbol_to_kegg,
by = c("gene_symbol" = "SYMBOL")
) %>%
mutate(
regulation = case_when(
is.na(padj) | padj >= padj_cutoff ~ "not_significant",
log2FC > 0 ~ "overexpressed",
log2FC < 0 ~ "underexpressed",
TRUE ~ "not_significant"
),
html_color = case_when(
regulation == "not_significant" ~ "#FFFF00", # yellow
regulation == "overexpressed" ~ "#FF0000",   # red
regulation == "underexpressed" ~ "#00FF00"   # green
)
) %>%
dplyr::select(
gene_symbol,
entrez_id = ENTREZID,
kegg_id,
log2FC,
padj,
regulation,
html_color
) %>%
arrange(gene_symbol)
}
walk(files, function(file) {
sheets <- excel_sheets(file)
sheet_results <- set_names(
map(sheets, ~ parse_deg_sheet(file, .x)),
sheets
)
file_prefix <- tools::file_path_sans_ext(basename(file))
output_file <- file.path(
output_dir,
paste0(file_prefix, "_glycolysis_KEGG_colors.xlsx")
)
write_xlsx(sheet_results, output_file)
# Save one colored KEGG glycolysis pathway image per sheet/comparison
imap(sheet_results, function(result_df, sheet_name) {
safe_sheet_name <- sheet_name %>%
str_replace_all("[^A-Za-z0-9_]+", "_") %>%
str_replace_all("_+", "_") %>%
str_remove("_$")
output_png <- file.path(
output_dir,
paste0(file_prefix, "_", safe_sheet_name, "_mmu00010_glycolysis.png")
)
tryCatch(
{
save_kegg_colored_pathway(
kegg_df = result_df,
pathway_id = "mmu00010",
output_png = output_png
)
},
error = function(e) {
warning(
"Skipping KEGG image for ",
file_prefix,
" / ",
sheet_name,
": ",
conditionMessage(e)
)
NA_character_
}
)
})
})
warnings()
