library(httr)
library(xml2)
pathway_id <- "mmu00010"
make_kegg_color_url <- function(kegg_df, pathway_id = "mmu00010") {
# KEGG expects lines like:
# mmu:12345 #FF0000,#000000
dataset <- kegg_df %>%
filter(!is.na(kegg_id), !is.na(html_color)) %>%
transmute(
line = paste0(kegg_id, " ", html_color, ",#000000")
) %>%
pull(line) %>%
paste(collapse = "\r\n")
paste0(
"https://www.kegg.jp/kegg-bin/show_pathway?",
"map=", pathway_id,
"&multi_query=", URLencode(dataset, reserved = TRUE)
)
}
